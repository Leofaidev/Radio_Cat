DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# --- Database ---
# Docker: DATABASE_URL=postgres://catuser:catpass@db:5432/catdb
# Local dev: DATABASE_URL=postgres://postgres:12345@localhost:5432/catbreeders_dev
DATABASE_URL=postgres://catuser:catpass@db:5432/catdb

# PostgreSQL credentials (used by the db service in docker-compose)
POSTGRES_USER=catuser
POSTGRES_PASSWORD=catpass
POSTGRES_DB=catdb

ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Frontend URL (used for CORS) ---
# Docker: http://localhost
# Local dev: http://localhost:4200
FRONTEND_URL=http://localhost

# --- Redis / Channel layer ---
# Leave empty to use the in-memory channel layer (local dev without Redis).
# Set to redis://redis:6379/0 for Docker or production.
REDIS_URL=
